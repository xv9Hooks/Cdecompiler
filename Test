local function formatNumber(n)
    if n ~= n then return "0/0" end
    if n == math.huge then return "math.huge" end
    if n == -math.huge then return "-math.huge" end
    if n == 0 then
        if 1/n == -math.huge then return "-0" end
        return "0"
    end
    if n == math.floor(n) and math.abs(n) < 2^53 then
        return string.format("%.0f", n)
    end
    return string.format("%.17g", n)
end

local function formatString(s)
    if s == nil then return '""' end
    local result = '"'
    for i = 1, #s do
        local c = string.byte(s, i)
        if c == 7 then result = result .. "\\a"
        elseif c == 8 then result = result .. "\\b"
        elseif c == 9 then result = result .. "\\t"
        elseif c == 10 then result = result .. "\\n"
        elseif c == 11 then result = result .. "\\v"
        elseif c == 12 then result = result .. "\\f"
        elseif c == 13 then result = result .. "\\r"
        elseif c == 34 then result = result .. '\\"'
        elseif c == 92 then result = result .. "\\\\"
        elseif c == 0 then result = result .. "\\0"
        elseif c < 32 or c > 126 then
            result = result .. string.format("\\%d", c)
        else
            result = result .. string.char(c)
        end
    end
    return result .. '"'
end

