local function isValidIdentifier(s)
    if s == nil or #s == 0 then return false end
    if not s:match("^[a-zA-Z_][a-zA-Z0-9_]*$") then return false end
    return not LUAU_RESERVED[s]
end

----------------------------------------------------------------------
-- BOLUM 3: Binary Reader
----------------------------------------------------------------------

local BinaryReader = {}
BinaryReader.__index = BinaryReader

function BinaryReader.new(data)
    return setmetatable({
        data = data,
        pos = 1,
        len = #data
    }, BinaryReader)
end

function BinaryReader:readByte()
    if self.pos > self.len then
        error("BinaryReader: EOF (pos=" .. self.pos .. ")")
    end
    local b = string.byte(self.data, self.pos)
    self.pos = self.pos + 1
    return b
end

function BinaryReader:readBytes(n)
    if self.pos + n - 1 > self.len then
        error("BinaryReader: EOF")
    end
    local bytes = string.sub(self.data, self.pos, self.pos + n - 1)
    self.pos = self.pos + n
    return bytes
end

function BinaryReader:readUInt32()
    local b1, b2, b3, b4 = string.byte(self.data, self.pos, self.pos + 3)
    self.pos = self.pos + 4
    return b1 + b2 * 256 + b3 * 65536 + b4 * 16777216
end

function BinaryReader:readInt32()
    local v = self:readUInt32()
    if v >= 2147483648 then
        v = v - 4294967296
    end
    return v
end

function BinaryReader:readFloat64()
    local bytes = self:readBytes(8)
    local b1, b2, b3, b4, b5, b6, b7, b8 = string.byte(bytes, 1, 8)

    local sign = 1
    if b8 >= 128 then
        sign = -1
        b8 = b8 - 128
    end

    local exponent = b8 * 16 + math.floor(b7 / 16)
    local mantissa = (b7 % 16) * 2^48
        + b6 * 2^40 + b5 * 2^32 + b4 * 2^24
        + b3 * 2^16 + b2 * 2^8 + b1

    if exponent == 0 and mantissa == 0 then
        return 0 * sign
    elseif exponent == 2047 then
        if mantissa == 0 then
            return sign * math.huge
        else
            return 0/0
        end
    end

    return sign * 2^(exponent - 1023) * (1 + mantissa / 2^52)
end

function BinaryReader:readFloat32()
    local bytes = self:readBytes(4)
    local b1, b2, b3, b4 = string.byte(bytes, 1, 4)

    local sign = 1
    if b4 >= 128 then
        sign = -1
        b4 = b4 - 128
    end

    local exponent = b4 * 2 + math.floor(b3 / 128)
    local mantissa = (b3 % 128) * 2^16 + b2 * 2^8 + b1

    if exponent == 0 and mantissa == 0 then
        return 0 * sign
    elseif exponent == 255 then
        if mantissa == 0 then
            return sign * math.huge
        else
            return 0/0
        end
    end

    return sign * 2^(exponent - 127) * (1 + mantissa / 2^23)
end

function BinaryReader:readVarInt()
    local result = 0
    local shift = 0
    while true do
        local b = self:readByte()
        result = result + bit32.band(b, 0x7F) * 2^shift
        if bit32.band(b, 0x80) == 0 then
            break
        end
        shift = shift + 7
    end
    return result
end

----------------------------------------------------------------------
-- BOLUM 4: Instruction Decoder
----------------------------------------------------------------------

local InstructionDecoder = {}

function InstructionDecoder.decode(word)
    local opcode = bit32.band(word, 0xFF)
    local inst = {
        opcode = opcode,
        raw = word,
        A = bit32.band(bit32.rshift(word, 8), 0xFF),
        B = bit32.band(bit32.rshift(word, 16), 0xFF),
        C = bit32.band(bit32.rshift(word, 24), 0xFF),
    }

    local d = bit32.band(bit32.rshift(word, 16), 0xFFFF)
    if d >= 32768 then d = d - 65536 end
    inst.D = d

    local e = bit32.band(bit32.rshift(word, 8), 0xFFFFFF)
    if e >= 8388608 then e = e - 16777216 end
    inst.E = e

    return inst
end

function InstructionDecoder.hasAux(opcode)
    return opcode == LOP.GETTABLEKS
        or opcode == LOP.SETTABLEKS
        or opcode == LOP.NAMECALL
        or opcode == LOP.JUMPIFEQ
        or opcode == LOP.JUMPIFLE
        or opcode == LOP.JUMPIFLT
        or opcode == LOP.JUMPIFNOTEQ
        or opcode == LOP.JUMPIFNOTLE
        or opcode == LOP.JUMPIFNOTLT
        or opcode == LOP.NEWTABLE
        or opcode == LOP.SETLIST
        or opcode == LOP.FORGLOOP
        or opcode == LOP.LOADKX
        or opcode == LOP.FASTCALL2
        or opcode == LOP.FASTCALL2K
        or opcode == LOP.JUMPXEQKNIL
        or opcode == LOP.JUMPXEQKB
        or opcode == LOP.JUMPXEQKN
        or opcode == LOP.JUMPXEQKS
        or opcode == LOP.GETIMPORT
end

----------------------------------------------------------------------
-- BOLUM 5: Bytecode Deserializer
----------------------------------------------------------------------

local Deserializer = {}

function Deserializer.resolveImport(importId, strings)
    local count = bit32.rshift(importId, 30)
    local parts = {}

    if count >= 1 then
        local k1 = bit32.band(bit32.rshift(importId, 20), 0x3FF)
        table.insert(parts, strings[k1 + 1] or ("k" .. k1))
    end
    if count >= 2 then
        local k2 = bit32.band(bit32.rshift(importId, 10), 0x3FF)
        table.insert(parts, strings[k2 + 1] or ("k" .. k2))
    end
    if count >= 3 then
        local k3 = bit32.band(importId, 0x3FF)
        table.insert(parts, strings[k3 + 1] or ("k" .. k3))
    end

    return table.concat(parts, ".")
end

function Deserializer.readProto(reader, strings, version, typesVersion)
    local proto = {}

    proto.maxstacksize = reader:readByte()
    proto.numparams = reader:readByte()
    proto.nups = reader:readByte()
    proto.isvararg = reader:readByte() ~= 0

    if typesVersion >= 1 then
        local typeSize = reader:readVarInt()
        if typeSize > 0 then
            proto.typeinfo = reader:readBytes(typeSize)
        end
    end

    local codeSize = reader:readVarInt()
    local code = table.create(codeSize)
    for j = 1, codeSize do
        code[j] = reader:readUInt32()
    end
    proto.code = code
    proto.sizecode = codeSize

    -- Decode instructions
    local instructions = {}
    local pc = 1
    while pc <= codeSize do
        local inst = InstructionDecoder.decode(code[pc])
        inst.pc = pc
        instructions[pc] = inst

        if InstructionDecoder.hasAux(inst.opcode) and pc + 1 <= codeSize then
            inst.aux = code[pc + 1]
            instructions[pc + 1] = { opcode = -1, isAux = true, value = code[pc + 1], pc = pc + 1 }
            pc = pc + 2
        else
            pc = pc + 1
        end
    end
    proto.instructions = instructions

    -- Constants
    local constantCount = reader:readVarInt()
    local constants = table.create(constantCount)

    for j = 1, constantCount do
        local ctype = reader:readByte()
        local constant = { type = ctype }

        if ctype == CONST_NIL then
            constant.value = nil
            constant.display = "nil"
        elseif ctype == CONST_BOOLEAN then
            constant.value = reader:readByte() ~= 0
            constant.display = tostring(constant.value)
        elseif ctype == CONST_NUMBER then
            constant.value = reader:readFloat64()
            constant.display = formatNumber(constant.value)
        elseif ctype == CONST_STRING then
            local idx = reader:readVarInt()
            constant.value = strings[idx + 1]
            constant.display = formatString(constant.value)
            constant.stringIndex = idx
        elseif ctype == CONST_IMPORT then
            local importIdVal = reader:readUInt32()
            constant.value = importIdVal
            constant.display = Deserializer.resolveImport(importIdVal, strings)
            constant.importId = importIdVal
        elseif ctype == CONST_TABLE then
            local tableSize = reader:readVarInt()
            local keys = table.create(tableSize)
            for k = 1, tableSize do
                keys[k] = reader:readVarInt()
            end
            constant.value = keys
            constant.display = "{table_template}"
        elseif ctype == CONST_CLOSURE then
            local closureId = reader:readVarInt()
            constant.value = closureId
            constant.display = "closure_" .. closureId
        elseif ctype == CONST_VECTOR then
            local x = reader:readFloat32()
            local y = reader:readFloat32()
            local z = reader:readFloat32()
            local w = reader:readFloat32()
            constant.value = {x, y, z, w}
            constant.display = string.format("Vector3.new(%s, %s, %s)",
                formatNumber(x), formatNumber(y), formatNumber(z))
        else
            constant.value = nil
            constant.display = "unknown_const_" .. ctype
        end

        constants[j] = constant
    end
    proto.constants = constants
    proto.sizek = constantCount

    -- Child protos
    local childCount = reader:readVarInt()
    local children = table.create(childCount)
    for j = 1, childCount do
        children[j] = reader:readVarInt() + 1
    end
    proto.children = children

    -- Line info (opsiyonel, skip edebiliriz ama dogru okumamiz lazim)
    local hasLineInfo = reader:readByte()
    if hasLineInfo ~= 0 then
        local linegaplog2 = reader:readByte()
        local intervals = math.floor((proto.sizecode - 1) / (2^linegaplog2)) + 1

        -- Line offsets (sizecode adet byte)
        local lineinfo = table.create(proto.sizecode)
        local lastoffset = 0
        for j = 1, proto.sizecode do
            local offset = reader:readByte()
            if offset >= 128 then
                offset = offset - 256
            end
            lastoffset = lastoffset + offset
            lineinfo[j] = lastoffset
        end

        -- Absolute line info (intervals adet int32)
        local abslineinfo = table.create(intervals)
        for j = 1, intervals do
            abslineinfo[j] = reader:readInt32()
        end

        proto.lineinfo = lineinfo
        proto.abslineinfo = abslineinfo
        proto.linegaplog2 = linegaplog2
    end

    -- Debug info
    local hasDebugInfo = reader:readByte()
    if hasDebugInfo ~= 0 then
        local localCount = reader:readVarInt()
        local debugLocals = table.create(localCount)
        for j = 1, localCount do
            local loc = {}
            local nameIdx = reader:readVarInt()
            loc.name = strings[nameIdx + 1]
            loc.startpc = reader:readVarInt()
            loc.endpc = reader:readVarInt()
            loc.reg = reader:readByte()
            debugLocals[j] = loc
        end
        proto.debugLocals = debugLocals

        local upvalCount = reader:readVarInt()
        local debugUpvalues = table.create(upvalCount)
        for j = 1, upvalCount do
            local nameIdx = reader:readVarInt()
            debugUpvalues[j] = strings[nameIdx + 1]
        end
        proto.debugUpvalues = debugUpvalues
    end

    return proto
end

function Deserializer.deserialize(data)
    local reader = BinaryReader.new(data)
    local mod = {}

    local version = reader:readByte()
    if version == 0 then
        local errorLen = reader:readVarInt()
        local errorMsg = reader:readBytes(errorLen)
        error("Bytecode compile error: " .. errorMsg)
    end
    mod.version = version

    local typesVersion = 0
    if version >= 4 then
        typesVersion = reader:readByte()
    end
    mod.typesVersion = typesVersion

    local stringCount = reader:readVarInt()
    local strings = table.create(stringCount)
    for i = 1, stringCount do
        local len = reader:readVarInt()
        strings[i] = reader:readBytes(len)
    end
    mod.strings = strings

    local protoCount = reader:readVarInt()
    local protos = table.create(protoCount)
    for i = 1, protoCount do
        local proto = Deserializer.readProto(reader, strings, version, typesVersion)
        proto.id = i - 1
        protos[i] = proto
    end
    mod.protos = protos

    local mainProtoId = reader:readVarInt()
    mod.mainProtoId = mainProtoId + 1

    return mod
end

----------------------------------------------------------------------
-- BOLUM 6: Expression Tracker
----------------------------------------------------------------------

local ExprTracker = {}
ExprTracker.__index = ExprTracker

function ExprTracker.new(proto, allProtos)
    local self = setmetatable({}, ExprTracker)
    self.proto = proto
    self.allProtos = allProtos
    self.regs = {}
    self.localNames = {}
    self.localDeclared = {}
    self.upvalueNames = {}
    self.tempCounter = 0
    self._isNamecall = nil

    -- Debug info'dan local isimleri
    if proto.debugLocals then
        for _, loc in ipairs(proto.debugLocals) do
            if loc.name and loc.name ~= "" then
                if not self.localNames[loc.reg] then
                    self.localNames[loc.reg] = loc.name
                end
            end
        end
    end

    -- Debug info'dan upvalue isimleri
    if proto.debugUpvalues then
        for i, name in ipairs(proto.debugUpvalues) do
            self.upvalueNames[i - 1] = name
        end
    end

    -- Parametreler
    for i = 0, proto.numparams - 1 do
        local name = self.localNames[i] or ("arg" .. i)
        self.localNames[i] = name
        self.localDeclared[i] = true
        self.regs[i] = name
    end

    return self
end

function ExprTracker:getLocalName(reg, pc)
    if self.proto.debugLocals then
        for _, loc in ipairs(self.proto.debugLocals) do
            if loc.reg == reg and pc >= loc.startpc and pc <= loc.endpc then
                return loc.name
            end
        end
    end
    return self.localNames[reg]
end

function ExprTracker:generateName(reg)
    if self.localNames[reg] then
        return self.localNames[reg]
    end
    self.tempCounter = self.tempCounter + 1
    local name = "v" .. self.tempCounter
    self.localNames[reg] = name
    return name
end

function ExprTracker:getUpvalueName(idx)
    return self.upvalueNames[idx] or ("upval_" .. idx)
end

function ExprTracker:getReg(reg)
    return self.regs[reg] or self:generateName(reg)
end

function ExprTracker:setReg(reg, expr)
    self.regs[reg] = expr
end

function ExprTracker:getConstant(idx)
    local k = self.proto.constants[idx + 1]
    if k == nil then return "nil" end
    if k.type == CONST_NIL then return "nil" end
    if k.type == CONST_BOOLEAN then return tostring(k.value) end
    if k.type == CONST_NUMBER then return formatNumber(k.value) end
    if k.type == CONST_STRING then return formatString(k.value) end
    if k.type == CONST_IMPORT then return k.display end
    if k.type == CONST_VECTOR then return k.display end
    return k.display or "nil"
end

function ExprTracker:getConstantString(idx)
    local k = self.proto.constants[idx + 1]
    if k and k.type == CONST_STRING then
        return k.value
    end
    return nil
end

----------------------------------------------------------------------
-- BOLUM 7: Statement Decompiler
----------------------------------------------------------------------

local StatementDecompiler = {}
StatementDecompiler.__index = StatementDecompiler

function StatementDecompiler.new(mod)
    local self = setmetatable({}, StatementDecompiler)
    self.mod = mod
    self.protos = mod.protos
    self.strings = mod.strings
    self.indentStr = "    "
    return self
end

function StatementDecompiler:decompile()
    local mainProto = self.protos[self.mod.mainProtoId]
    if not mainProto then
        error("Main proto not found")
    end
    return self:decompileFunction(mainProto, true, 0)
end

function StatementDecompiler:generateFunction(childProto, currentIndent)
    local params = {}
    for i = 0, childProto.numparams - 1 do
        local name = nil
        if childProto.debugLocals then
            for _, loc in ipairs(childProto.debugLocals) do
                if loc.reg == i and loc.startpc == 0 then
                    name = loc.name
                    break
                end
            end
        end
        table.insert(params, name or ("p" .. i))
    end
    if childProto.isvararg then
        table.insert(params, "...")
    end
    local paramStr = table.concat(params, ", ")

    local body = self:decompileFunction(childProto, false, currentIndent + 1)
    local bodyLines = {}
    for line in body:gmatch("[^\n]*") do
        if line ~= "" then
            table.insert(bodyLines, line)
        end
    end

    if #bodyLines == 0 then
        return "function(" .. paramStr .. ") end"
    elseif #bodyLines == 1 then
        local trimmed = bodyLines[1]:match("^%s*(.-)%s*$")
        if #trimmed < 60 then
            return "function(" .. paramStr .. ") " .. trimmed .. " end"
        end
    end

    local result = "function(" .. paramStr .. ")\n"
    result = result .. table.concat(bodyLines, "\n") .. "\n"
    result = result .. string.rep(self.indentStr, currentIndent) .. "end"
    return result
end

function StatementDecompiler:readsReg(inst, reg)
    local op = inst.opcode
    local A, B, C = inst.A, inst.B, inst.C
    if op == LOP.MOVE and B == reg then return true end
    if op == LOP.SETGLOBAL and A == reg then return true end
    if op == LOP.SETUPVAL and A == reg then return true end
    if op == LOP.SETTABLE and (A == reg or B == reg or C == reg) then return true end
    if op == LOP.SETTABLEKS and (A == reg or B == reg) then return true end
    if op == LOP.SETTABLEN and (A == reg or B == reg) then return true end
    if op == LOP.GETTABLE and (B == reg or C == reg) then return true end
    if op == LOP.GETTABLEKS and B == reg then return true end
    if op == LOP.GETTABLEN and B == reg then return true end
    if op >= LOP.ADD and op <= LOP.POW and (B == reg or C == reg) then return true end
    if op >= LOP.ADDK and op <= LOP.POWK and B == reg then return true end
    if op == LOP.IDIV and (B == reg or C == reg) then return true end
    if op == LOP.IDIVK and B == reg then return true end
    if op == LOP.SUBRK and B == reg then return true end
    if op == LOP.DIVRK and B == reg then return true end
    if op == LOP.AND and (B == reg or C == reg) then return true end
    if op == LOP.OR and (B == reg or C == reg) then return true end
    if op == LOP.ANDK and B == reg then return true end
    if op == LOP.ORK and B == reg then return true end
    if op == LOP.CONCAT and reg >= B and reg <= C then return true end
    if (op == LOP.NOT or op == LOP.MINUS or op == LOP.LENGTH) and B == reg then return true end
    if op == LOP.CALL then
        if A == reg then return true end
        local nargs = inst.B - 1
        if nargs > 0 then
            for i = 1, nargs do
                if A + i == reg then return true end
            end
        end
    end
    if op == LOP.RETURN then
        local n = inst.B - 1
        if n > 0 then
            for i = 0, n - 1 do
                if A + i == reg then return true end
            end
        end
    end
    if (op == LOP.JUMPIF or op == LOP.JUMPIFNOT) and A == reg then return true end
    if op >= LOP.JUMPIFEQ and op <= LOP.JUMPIFNOTLT and A == reg then return true end
    if op >= LOP.JUMPXEQKNIL and op <= LOP.JUMPXEQKS and A == reg then return true end
    if op == LOP.NAMECALL and B == reg then return true end
    if op == LOP.SETLIST then
        if A == reg then return true end
        local count = C - 1
        if count > 0 then
            for i = 0, count - 1 do
                if B + i == reg then return true end
            end
        end
    end
    return false
end

function StatementDecompiler:writesReg(inst, reg)
    local op = inst.opcode
    local A = inst.A
    if op == LOP.LOADNIL or op == LOP.LOADB or op == LOP.LOADN
        or op == LOP.LOADK or op == LOP.LOADKX
        or op == LOP.MOVE or op == LOP.GETGLOBAL
        or op == LOP.GETUPVAL or op == LOP.GETIMPORT
        or op == LOP.GETTABLE or op == LOP.GETTABLEKS
        or op == LOP.GETTABLEN or op == LOP.NEWCLOSURE
        or op == LOP.DUPCLOSURE or op == LOP.NEWTABLE
        or op == LOP.DUPTABLE
        or (op >= LOP.ADD and op <= LOP.POWK)
        or op == LOP.IDIV or op == LOP.IDIVK
        or op == LOP.SUBRK or op == LOP.DIVRK
        or op == LOP.AND or op == LOP.OR
        or op == LOP.ANDK or op == LOP.ORK
        or op == LOP.CONCAT or op == LOP.NOT
        or op == LOP.MINUS or op == LOP.LENGTH
        or op == LOP.GETVARARGS then
        return A == reg
    elseif op == LOP.CALL then
        local nres = inst.C - 1
        if nres > 0 then
            for i = 0, nres - 1 do
                if A + i == reg then return true end
            end
        end
        return false
    elseif op == LOP.NAMECALL then
        return A == reg or A + 1 == reg
    end
    return false
end

----------------------------------------------------------------------
-- BOLUM 8: Ana Decompile Fonksiyonu
----------------------------------------------------------------------

function StatementDecompiler:decompileFunction(proto, isMain, baseIndent)
    baseIndent = baseIndent or 0
    local tracker = ExprTracker.new(proto, self.protos)
    local lines = {}
    local indent = baseIndent
    local instructions = proto.instructions
    local blockEnds = {} -- pc -> list of block end types

    local function emit(code)
        table.insert(lines, string.rep(self.indentStr, indent) .. code)
    end

    local pc = 1
    while pc <= proto.sizecode do
        local inst = instructions[pc]

        if not inst or inst.isAux then
            pc = pc + 1
        else
            -- Block end kontrolu
            if blockEnds[pc] then
                for _, blockInfo in ipairs(blockEnds[pc]) do
                    if blockInfo == "end" then
                        indent = math.max(0, indent - 1)
                        emit("end")
                    elseif blockInfo == "else" then
                        indent = math.max(0, indent - 1)
                        emit("else")
                        indent = indent + 1
                    end
                end
            end

            local op = inst.opcode
            local A, B, C, D = inst.A, inst.B, inst.C, inst.D
            local didAdvance = false

            -- ===== NOP / Internal =====
            if op == LOP.NOP or op == LOP.BREAK or op == LOP.COVERAGE
                or op == LOP.NATIVECALL or op == LOP.PREPVARARGS
                or op == LOP.CLOSEUPVALS then
                -- skip

            -- ===== LOADNIL =====
            elseif op == LOP.LOADNIL then
                tracker:setReg(A, "nil")

            -- ===== LOADB =====
            elseif op == LOP.LOADB then
                tracker:setReg(A, B ~= 0 and "true" or "false")

            -- ===== LOADN =====
            elseif op == LOP.LOADN then
                tracker:setReg(A, formatNumber(D))

            -- ===== LOADK =====
            elseif op == LOP.LOADK then
                tracker:setReg(A, tracker:getConstant(D))

            -- ===== LOADKX =====
            elseif op == LOP.LOADKX then
                tracker:setReg(A, tracker:getConstant(inst.aux or 0))

            -- ===== MOVE =====
            elseif op == LOP.MOVE then
                tracker:setReg(A, tracker:getReg(B))

            -- ===== GETGLOBAL =====
            elseif op == LOP.GETGLOBAL then
                local aux = inst.aux or 0
                local name = tracker:getConstantString(aux) or ("_G[" .. aux .. "]")
                tracker:setReg(A, name)

            -- ===== SETGLOBAL =====
            elseif op == LOP.SETGLOBAL then
                local aux = inst.aux or 0
                local name = tracker:getConstantString(aux) or ("_G[" .. aux .. "]")
                emit(name .. " = " .. tracker:getReg(A))

            -- ===== GETUPVAL =====
            elseif op == LOP.GETUPVAL then
                tracker:setReg(A, tracker:getUpvalueName(B))

            -- ===== SETUPVAL =====
            elseif op == LOP.SETUPVAL then
                emit(tracker:getUpvalueName(B) .. " = " .. tracker:getReg(A))

            -- ===== GETIMPORT =====
            elseif op == LOP.GETIMPORT then
                local k = proto.constants[D + 1]
                if k and k.type == CONST_IMPORT then
                    tracker:setReg(A, k.display)
                else
                    tracker:setReg(A, "import_" .. D)
                end

            -- ===== GETTABLE =====
            elseif op == LOP.GETTABLE then
                tracker:setReg(A, tracker:getReg(B) .. "[" .. tracker:getReg(C) .. "]")

            -- ===== SETTABLE =====
            elseif op == LOP.SETTABLE then
                emit(tracker:getReg(B) .. "[" .. tracker:getReg(C) .. "] = " .. tracker:getReg(A))

            -- ===== GETTABLEKS =====
            elseif op == LOP.GETTABLEKS then
                local aux = inst.aux or 0
                local key = tracker:getConstantString(aux)
                local tbl = tracker:getReg(B)
                if key and isValidIdentifier(key) then
                    tracker:setReg(A, tbl .. "." .. key)
                elseif key then
                    tracker:setReg(A, tbl .. "[" .. formatString(key) .. "]")
                else
                    tracker:setReg(A, tbl .. "[" .. tracker:getConstant(aux) .. "]")
                end

            -- ===== SETTABLEKS =====
            elseif op == LOP.SETTABLEKS then
                local aux = inst.aux or 0
                local key = tracker:getConstantString(aux)
                local tbl = tracker:getReg(B)
                local val = tracker:getReg(A)
                local lhs
                if key and isValidIdentifier(key) then
                    lhs = tbl .. "." .. key
                elseif key then
                    lhs = tbl .. "[" .. formatString(key) .. "]"
                else
                    lhs = tbl .. "[" .. tracker:getConstant(aux) .. "]"
                end
                emit(lhs .. " = " .. val)

            -- ===== GETTABLEN =====
            elseif op == LOP.GETTABLEN then
                tracker:setReg(A, tracker:getReg(B) .. "[" .. (C + 1) .. "]")

            -- ===== SETTABLEN =====
            elseif op == LOP.SETTABLEN then
                emit(tracker:getReg(B) .. "[" .. (C + 1) .. "] = " .. tracker:getReg(A))

            -- ===== NEWCLOSURE =====
            elseif op == LOP.NEWCLOSURE then
                local childIdx = proto.children[D + 1]
                if childIdx and self.protos[childIdx] then
                    tracker:setReg(A, self:generateFunction(self.protos[childIdx], indent))
                else
                    tracker:setReg(A, "function() end")
                end
                -- Skip CAPTURE instructions
                local nextPC = pc + 1
                while nextPC <= proto.sizecode do
                    local ni = instructions[nextPC]
                    if ni and ni.opcode == LOP.CAPTURE then
                        nextPC = nextPC + 1
                    else
                        break
                    end
                end
                pc = nextPC
                didAdvance = true

            -- ===== DUPCLOSURE =====
            elseif op == LOP.DUPCLOSURE then
                local k = proto.constants[D + 1]
                local closureIdx = nil
                if k and k.type == CONST_CLOSURE then
                    closureIdx = k.value + 1
                end
                if closureIdx and self.protos[closureIdx] then
                    tracker:setReg(A, self:generateFunction(self.protos[closureIdx], indent))
                else
                    tracker:setReg(A, "function() end")
                end
                -- Skip CAPTURE instructions
                local nextPC = pc + 1
                while nextPC <= proto.sizecode do
                    local ni = instructions[nextPC]
                    if ni and ni.opcode == LOP.CAPTURE then
                        nextPC = nextPC + 1
                    else
                        break
                    end
                end
                pc = nextPC
                didAdvance = true

            -- ===== NAMECALL =====
            elseif op == LOP.NAMECALL then
                local tbl = tracker:getReg(B)
                local aux = inst.aux or 0
                local method = tracker:getConstantString(aux)
                tracker:setReg(A + 1, tbl)
                if method and isValidIdentifier(method) then
                    tracker:setReg(A, tbl .. ":" .. method)
                else
                    local mDisp = method and formatString(method) or tracker:getConstant(aux)
                    tracker:setReg(A, tbl .. "[" .. mDisp .. "]")
                end
                tracker._isNamecall = A

            -- ===== CALL =====
            elseif op == LOP.CALL then
                local func = tracker:getReg(A)
                local nargs = B - 1
                local nresults = C - 1
                local isNC = (tracker._isNamecall == A)

                local args = {}
                if nargs >= 0 then
                    local startArg = isNC and 2 or 1
                    for i = startArg, nargs do
                        table.insert(args, tracker:getReg(A + i))
                    end
                else
                    local startIdx = isNC and (A + 2) or (A + 1)
                    for i = startIdx, proto.maxstacksize - 1 do
                        local v = tracker.regs[i]
                        if v then
                            table.insert(args, v)
                        else
                            break
                        end
                    end
                end
                tracker._isNamecall = nil

                local callExpr = func .. "(" .. table.concat(args, ", ") .. ")"

                if nresults == 0 then
                    -- Vararg sonuc, genelde sonraki RETURN icin
                    tracker:setReg(A, callExpr)
                elseif nresults == 1 then
                    -- Side effect call, sonuc yok
                    emit(callExpr)
                elseif nresults == 2 then
                    -- 1 sonuc
                    tracker:setReg(A, callExpr)
                    -- Sonraki instruction'a bakalim, kullaniliyor mu?
                    local usedSoon = false
                    for spc = pc + 1, math.min(pc + 10, proto.sizecode) do
                        local si = instructions[spc]
                        if si and not si.isAux then
                            if self:readsReg(si, A) then
                                usedSoon = true
                                break
                            end
                            if self:writesReg(si, A) then
                                break
                            end
                        end
                    end
                    if not usedSoon then
                        local name = tracker:generateName(A)
                        if not tracker.localDeclared[A] then
                            tracker.localDeclared[A] = true
                            emit("local " .. name .. " = " .. callExpr)
                        else
                            emit(name .. " = " .. callExpr)
                        end
                        tracker:setReg(A, name)
                    end
                else
                    -- Coklu sonuc
                    local rcount = nresults - 1
                    local names = {}
                    for i = 0, rcount - 1 do
                        local name = tracker:generateName(A + i)
                        tracker:setReg(A + i, name)
                        table.insert(names, name)
                    end
                    local anyNew = false
                    for i = 0, rcount - 1 do
                        if not tracker.localDeclared[A + i] then
                            anyNew = true
                            tracker.localDeclared[A + i] = true
                        end
                    end
                    local nameStr = table.concat(names, ", ")
                    if anyNew then
                        emit("local " .. nameStr .. " = " .. callExpr)
                    else
                        emit(nameStr .. " = " .. callExpr)
                    end
                end

            -- ===== RETURN =====
            elseif op == LOP.RETURN then
                local nrets = B - 1
                if nrets == 0 then
                    if not isMain then
                        emit("return")
                    end
                elseif nrets < 0 then
                    emit("return " .. tracker:getReg(A))
                else
                    local rets = {}
                    for i = 0, nrets - 1 do
                        table.insert(rets, tracker:getReg(A + i))
                    end
                    emit("return " .. table.concat(rets, ", "))
                end

            -- ===== JUMP =====
            elseif op == LOP.JUMP then
                -- Forward jump = muhtemelen else/end/break
                -- Simdilik context'e birakiyoruz

            -- ===== JUMPBACK =====
            elseif op == LOP.JUMPBACK then
                indent = math.max(0, indent - 1)
                emit("end")

            -- ===== JUMPIF =====
            elseif op == LOP.JUMPIF then
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPIFNOT =====
            elseif op == LOP.JUMPIFNOT then
                local target = pc + D
                local cond = tracker:getReg(A)

                -- While pattern: target'in yakininda JUMPBACK var mi?
                local isWhile = false
                for chk = math.max(1, target - 2), math.min(target, proto.sizecode) do
                    local ci = instructions[chk]
                    if ci and ci.opcode == LOP.JUMPBACK then
                        isWhile = true
                        break
                    end
                end

                if isWhile then
                    emit("while " .. cond .. " do")
                    indent = indent + 1
                else
                    emit("if " .. cond .. " then")
                    indent = indent + 1
                    if not blockEnds[target] then blockEnds[target] = {} end
                    table.insert(blockEnds[target], "end")
                end

            -- ===== JUMPIFEQ =====
            elseif op == LOP.JUMPIFEQ then
                local aux = inst.aux or 0
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " == " .. tracker:getReg(aux) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPIFLE =====
            elseif op == LOP.JUMPIFLE then
                local aux = inst.aux or 0
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " <= " .. tracker:getReg(aux) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPIFLT =====
            elseif op == LOP.JUMPIFLT then
                local aux = inst.aux or 0
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " < " .. tracker:getReg(aux) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPIFNOTEQ =====
            elseif op == LOP.JUMPIFNOTEQ then
                local aux = inst.aux or 0
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " ~= " .. tracker:getReg(aux) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPIFNOTLE =====
            elseif op == LOP.JUMPIFNOTLE then
                local aux = inst.aux or 0
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " > " .. tracker:getReg(aux) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPIFNOTLT =====
            elseif op == LOP.JUMPIFNOTLT then
                local aux = inst.aux or 0
                local target = pc + D
                emit("if " .. tracker:getReg(A) .. " >= " .. tracker:getReg(aux) .. " then")
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPXEQKNIL =====
            elseif op == LOP.JUMPXEQKNIL then
                local aux = inst.aux or 0
                local isNot = bit32.band(aux, 0x80000000) ~= 0
                local target = pc + D
                local cond = tracker:getReg(A)
                if isNot then
                    emit("if " .. cond .. " ~= nil then")
                else
                    emit("if " .. cond .. " == nil then")
                end
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPXEQKB =====
            elseif op == LOP.JUMPXEQKB then
                local aux = inst.aux or 0
                local bval = bit32.band(aux, 1) ~= 0
                local isNot = bit32.band(aux, 0x80000000) ~= 0
                local target = pc + D
                local cond = tracker:getReg(A)
                if isNot then
                    emit("if " .. cond .. " ~= " .. tostring(bval) .. " then")
                else
                    emit("if " .. cond .. " == " .. tostring(bval) .. " then")
                end
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPXEQKN =====
            elseif op == LOP.JUMPXEQKN then
                local aux = inst.aux or 0
                local kIdx = bit32.band(aux, 0x00FFFFFF)
                local isNot = bit32.band(aux, 0x80000000) ~= 0
                local target = pc + D
                local cond = tracker:getReg(A)
                local kval = tracker:getConstant(kIdx)
                if isNot then
                    emit("if " .. cond .. " ~= " .. kval .. " then")
                else
                    emit("if " .. cond .. " == " .. kval .. " then")
                end
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPXEQKS =====
            elseif op == LOP.JUMPXEQKS then
                local aux = inst.aux or 0
                local kIdx = bit32.band(aux, 0x00FFFFFF)
                local isNot = bit32.band(aux, 0x80000000) ~= 0
                local target = pc + D
                local cond = tracker:getReg(A)
                local kval = tracker:getConstant(kIdx)
                if isNot then
                    emit("if " .. cond .. " ~= " .. kval .. " then")
                else
                    emit("if " .. cond .. " == " .. kval .. " then")
                end
                indent = indent + 1
                if not blockEnds[target] then blockEnds[target] = {} end
                table.insert(blockEnds[target], "end")

            -- ===== JUMPX =====
            elseif op == LOP.JUMPX then
                -- Extended jump, context-based

            -- ===== Arithmetic (register) =====
            elseif op == LOP.ADD then
                tracker:setReg(A, tracker:getReg(B) .. " + " .. tracker:getReg(C))
            elseif op == LOP.SUB then
                tracker:setReg(A, tracker:getReg(B) .. " - " .. tracker:getReg(C))
            elseif op == LOP.MUL then
                tracker:setReg(A, tracker:getReg(B) .. " * " .. tracker:getReg(C))
            elseif op == LOP.DIV then
                tracker:setReg(A, tracker:getReg(B) .. " / " .. tracker:getReg(C))
            elseif op == LOP.MOD then
                tracker:setReg(A, tracker:getReg(B) .. " % " .. tracker:getReg(C))
            elseif op == LOP.POW then
                tracker:setReg(A, tracker:getReg(B) .. " ^ " .. tracker:getReg(C))
            elseif op == LOP.IDIV then
                tracker:setReg(A, tracker:getReg(B) .. " // " .. tracker:getReg(C))

            -- ===== Arithmetic (constant) =====
            elseif op == LOP.ADDK then
                tracker:setReg(A, tracker:getReg(B) .. " + " .. tracker:getConstant(C))
            elseif op == LOP.SUBK then
                tracker:setReg(A, tracker:getReg(B) .. " - " .. tracker:getConstant(C))
            elseif op == LOP.MULK then
                tracker:setReg(A, tracker:getReg(B) .. " * " .. tracker:getConstant(C))
            elseif op == LOP.DIVK then
                tracker:setReg(A, tracker:getReg(B) .. " / " .. tracker:getConstant(C))
            elseif op == LOP.MODK then
                tracker:setReg(A, tracker:getReg(B) .. " % " .. tracker:getConstant(C))
            elseif op == LOP.POWK then
                tracker:setReg(A, tracker:getReg(B) .. " ^ " .. tracker:getConstant(C))
            elseif op == LOP.IDIVK then
                tracker:setReg(A, tracker:getReg(B) .. " // " .. tracker:getConstant(C))

            -- ===== Reverse arithmetic =====
            elseif op == LOP.SUBRK then
                tracker:setReg(A, tracker:getConstant(C) .. " - " .. tracker:getReg(B))
            elseif op == LOP.DIVRK then
                tracker:setReg(A, tracker:getConstant(C) .. " / " .. tracker:getReg(B))

            -- ===== Logical =====
            elseif op == LOP.AND then
                tracker:setReg(A, tracker:getReg(B) .. " and " .. tracker:getReg(C))
            elseif op == LOP.OR then
                tracker:setReg(A, tracker:getReg(B) .. " or " .. tracker:getReg(C))
            elseif op == LOP.ANDK then
                tracker:setReg(A, tracker:getReg(B) .. " and " .. tracker:getConstant(C))
            elseif op == LOP.ORK then
                tracker:setReg(A, tracker:getReg(B) .. " or " .. tracker:getConstant(C))

            -- ===== Unary =====
            elseif op == LOP.NOT then
                tracker:setReg(A, "not " .. tracker:getReg(B))
            elseif op == LOP.MINUS then
                local val = tracker:getReg(B)
                if val:match("^%-") or val:match("^%d") then
                    tracker:setReg(A, "-(" .. val .. ")")
                else
                    tracker:setReg(A, "-" .. val)
                end
            elseif op == LOP.LENGTH then
                tracker:setReg(A, "#" .. tracker:getReg(B))

            -- ===== CONCAT =====
            elseif op == LOP.CONCAT then
                local parts = {}
                for i = B, C do
                    table.insert(parts, tracker:getReg(i))
                end
                tracker:setReg(A, table.concat(parts, " .. "))

            -- ===== NEWTABLE =====
            elseif op == LOP.NEWTABLE then
                tracker:setReg(A, "{}")

            -- ===== DUPTABLE =====
            elseif op == LOP.DUPTABLE then
                tracker:setReg(A, "{}")

            -- ===== SETLIST =====
            elseif op == LOP.SETLIST then
                local count = C - 1
                local vals = {}
                if count >= 0 then
                    for i = 0, count - 1 do
                        table.insert(vals, tracker:getReg(B + i))
                    end
                end
                if #vals > 0 then
                    tracker:setReg(A, "{" .. table.concat(vals, ", ") .. "}")
                end

            -- ===== FORNPREP =====
            elseif op == LOP.FORNPREP then
                local init = tracker:getReg(A + 2)
                local limit = tracker:getReg(A)
                local step = tracker:getReg(A + 1)
                local varName = tracker:getLocalName(A + 3, pc) or tracker:generateName(A + 3)
                tracker:setReg(A + 3, varName)
                tracker.localDeclared[A + 3] = true

                if step == "1" then
                    emit("for " .. varName .. " = " .. init .. ", " .. limit .. " do")
                else
                    emit("for " .. varName .. " = " .. init .. ", " .. limit .. ", " .. step .. " do")
                end
                indent = indent + 1

            -- ===== FORNLOOP =====
            elseif op == LOP.FORNLOOP then
                indent = math.max(0, indent - 1)
                emit("end")

            -- ===== FORGPREP / FORGPREP_INEXT / FORGPREP_NEXT =====
            elseif op == LOP.FORGPREP or op == LOP.FORGPREP_INEXT or op == LOP.FORGPREP_NEXT then
                local iterExpr = tracker:getReg(A)

                -- FORGLOOP'u bul
                local forgLoopPC = nil
                for spc = pc + 1, proto.sizecode do
                    local si = instructions[spc]
                    if si and si.opcode == LOP.FORGLOOP and si.A == A then
                        forgLoopPC = spc
                        break
                    end
                end

                if forgLoopPC then
                    local forgInst = instructions[forgLoopPC]
                    local forgAux = forgInst.aux or 0
                    local numVars = bit32.band(forgAux, 0xFF)

                    local vars = {}
                    for i = 0, numVars - 1 do
                        local name = tracker:getLocalName(A + 3 + i, pc) or tracker:generateName(A + 3 + i)
                        tracker:setReg(A + 3 + i, name)
                        tracker.localDeclared[A + 3 + i] = true
                        table.insert(vars, name)
                    end

                    local varStr = table.concat(vars, ", ")
                    local iterStr
                    if op == LOP.FORGPREP_INEXT then
                        if iterExpr:match("^ipairs") then
                            iterStr = iterExpr
                        else
                            iterStr = "ipairs(" .. iterExpr .. ")"
                        end
                    elseif op == LOP.FORGPREP_NEXT then
                        if iterExpr:match("^pairs") then
                            iterStr = iterExpr
                        else
                            iterStr = "pairs(" .. iterExpr .. ")"
                        end
                    else
                        iterStr = iterExpr
                    end

                    emit("for " .. varStr .. " in " .. iterStr .. " do")
                    indent = indent + 1
                end

            -- ===== FORGLOOP =====
            elseif op == LOP.FORGLOOP then
                indent = math.max(0, indent - 1)
                emit("end")

            -- ===== Deprecated for =====
            elseif op == LOP.DEP_FORGLOOP_INEXT or op == LOP.DEP_FORGLOOP_NEXT then
                -- skip

            -- ===== GETVARARGS =====
            elseif op == LOP.GETVARARGS then
                local count = B - 1
                tracker:setReg(A, "...")
                if count > 1 then
                    for i = 1, count - 1 do
                        tracker:setReg(A + i, "...")
                    end
                end

            -- ===== CAPTURE =====
            elseif op == LOP.CAPTURE then
                -- skip, NEWCLOSURE handles this

            -- ===== FASTCALL =====
            elseif op == LOP.FASTCALL or op == LOP.FASTCALL1
                or op == LOP.FASTCALL2 or op == LOP.FASTCALL2K then
                -- skip, CALL handles this

            -- ===== UNKNOWN =====
            else
                emit("-- [unknown opcode " .. op .. " (" .. (LOP_NAMES[op] or "?") .. ")]")
            end

            -- PC ilerlet
            if not didAdvance then
                if InstructionDecoder.hasAux(op) then
                    pc = pc + 2
                else
                    pc = pc + 1
                end
            end
        end
    end

    return table.concat(lines, "\n")
end

----------------------------------------------------------------------
-- BOLUM 9: Public API
----------------------------------------------------------------------

function Decompiler.decompileFromBytecode(bytecodeData)
    local ok, mod = pcall(Deserializer.deserialize, bytecodeData)
    if not ok then
        return "-- Decompile error (deserialize): " .. tostring(mod)
    end

    local dec = StatementDecompiler.new(mod)
    local ok2, result = pcall(dec.decompile, dec)
    if not ok2 then
        return "-- Decompile error (engine): " .. tostring(result)
    end

    return "-- Decompiled with LuauDecompiler v6t3\n" .. result
end

function Decompiler.decompile(scriptInstance)
    if type(scriptInstance) == "string" then
        return Decompiler.decompileFromBytecode(scriptInstance)
    end

    -- Executor'dan bytecode al
    local getBytecode = nil
    if type(getscriptbytecode) == "function" then
        getBytecode = getscriptbytecode
    elseif type(getscriptbytes) == "function" then
        getBytecode = getscriptbytes
    end

    if not getBytecode then
        return "-- Error: getscriptbytecode not available"
    end

    local ok, bytecode = pcall(getBytecode, scriptInstance)
    if not ok then
        return "-- Error getting bytecode: " .. tostring(bytecode)
    end

    if not bytecode or #bytecode == 0 then
        return "-- Error: empty bytecode"
    end

    return Decompiler.decompileFromBytecode(bytecode)
end

----------------------------------------------------------------------
-- BOLUM 10: Override Sistemi
----------------------------------------------------------------------

function Decompiler.override()
    -- getgenv varsa executor ortamindayiz
    local env = nil
    if type(getgenv) == "function" then
        env = getgenv()
    end

    if not env then
        return false
    end

    -- Orijinal decompile'i yedekle
    local originalDecompile = rawget(env, "decompile")
    local originalGetBytecode = rawget(env, "getscriptbytecode") or rawget(env, "getscriptbytes")

    -- Yeni decompile fonksiyonu
    rawset(env, "decompile", function(target)
        -- Once bytecode'u al
        local bytecodeFunc = originalGetBytecode
        if not bytecodeFunc then
            if type(getscriptbytecode) == "function" then
                bytecodeFunc = getscriptbytecode
            elseif type(getscriptbytes) == "function" then
                bytecodeFunc = getscriptbytes
            end
        end

        if not bytecodeFunc then
            -- Bytecode alamiyorsak orijinal decompiler'a fallback
            if originalDecompile then
                return originalDecompile(target)
            end
            return "-- Error: No bytecode function available"
        end

        -- Bytecode'u al
        local ok, bytecode = pcall(bytecodeFunc, target)
        if not ok or not bytecode or #bytecode == 0 then
            -- Bytecode alinamazsa orijinale fallback
            if originalDecompile then
                return originalDecompile(target)
            end
            return "-- Error getting bytecode: " .. tostring(bytecode)
        end

        -- Bizim decompiler ile dene
        local ok2, result = pcall(Decompiler.decompileFromBytecode, bytecode)
        if ok2 and result and not result:match("^%-%- Decompile error") then
            return result
        end

        -- Basarisiz olursa orijinale fallback
        if originalDecompile then
            return originalDecompile(target)
        end

        return result or "-- Decompile failed"
    end)

    -- Syn.decompile override
    if type(syn) == "table" and type(rawget(syn, "decompile")) == "function" then
        local origSyn = rawget(syn, "decompile")
        rawset(syn, "decompile", function(target)
            local bytecodeFunc = originalGetBytecode
            if not bytecodeFunc then
                if type(getscriptbytecode) == "function" then
                    bytecodeFunc = getscriptbytecode
                elseif type(getscriptbytes) == "function" then
                    bytecodeFunc = getscriptbytes
                end
            end

            if bytecodeFunc then
                local ok, bytecode = pcall(bytecodeFunc, target)
                if ok and bytecode and #bytecode > 0 then
                    local ok2, result = pcall(Decompiler.decompileFromBytecode, bytecode)
                    if ok2 and result and not result:match("^%-%- Decompile error") then
                        return result
                    end
                end
            end

            return origSyn(target)
        end)
    end

    return true
end

----------------------------------------------------------------------
-- BOLUM 11: Disassembler
----------------------------------------------------------------------

function Decompiler.disassemble(bytecodeData)
    local mod = Deserializer.deserialize(bytecodeData)
    local lines = {}

    table.insert(lines, "-- Luau Bytecode v" .. mod.version .. " (types " .. mod.typesVersion .. ")")
    table.insert(lines, "-- Strings: " .. #mod.strings)
    table.insert(lines, "-- Protos: " .. #mod.protos)
    table.insert(lines, "-- Main: " .. mod.mainProtoId)
    table.insert(lines, "")

    for i, proto in ipairs(mod.protos) do
        table.insert(lines, "=== Proto " .. (i-1) .. " ===")
        table.insert(lines, "  params=" .. proto.numparams
            .. " ups=" .. proto.nups
            .. " stack=" .. proto.maxstacksize
            .. " vararg=" .. tostring(proto.isvararg))

        if proto.debugLocals then
            for j, loc in ipairs(proto.debugLocals) do
                table.insert(lines, string.format("  L%d: %s R%d [%d-%d]",
                    j-1, loc.name or "?", loc.reg, loc.startpc, loc.endpc))
            end
        end

        for j, k in ipairs(proto.constants) do
            table.insert(lines, "  K" .. (j-1) .. " = " .. (k.display or "?"))
        end

        for pcIdx = 1, proto.sizecode do
            local inst = proto.instructions[pcIdx]
            if inst then
                if inst.isAux then
                    table.insert(lines, string.format("  [%04d] AUX 0x%08X", pcIdx, inst.value))
                else
                    local opName = LOP_NAMES[inst.opcode] or ("OP_" .. inst.opcode)
                    table.insert(lines, string.format("  [%04d] %-18s A=%d B=%d C=%d D=%d",
                        pcIdx, opName, inst.A, inst.B, inst.C, inst.D))
                end
            end
        end
        table.insert(lines, "")
    end

    return table.concat(lines, "\n")
end


local function tryAutoOverride()
    if type(getgenv) == "function" then
        pcall(Decompiler.override)
    elseif type(syn) == "table" then
        pcall(Decompiler.override)
    end
end

tryAutoOverride()

return Decompiler
